{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "AutoHotkey Debug",
            "type": "autohotkey",
            "request": "launch",
            "program": "${file}"
        },
        {
            "type": "extendscript-debug",
            "request": "launch",
            "name": "Launch Script in ExtendScript Engine",
            "bringToFront": true,
            "hostAppSpecifier": "premierepro-25.0",
            "script": "${file}"
        }
    ]
}